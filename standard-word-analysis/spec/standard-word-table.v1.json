{
  "name": "standard-word-table",
  "version": "v1",
  "description": "标准词表（数据交换层）v1，当前版本包含【对应域名】与【gefeiKD】列，兼容 word-from-root 与 word-monitor-sub-domain 的 Excel 输出",
  "scope": {
    "includes": [
      "keyword seeds",
      "corresponding domain mapping",
      "sim metrics",
      "sem metrics",
      "score based on sim fields",
      "gefei kd"
    ],
    "excludes": []
  },
  "scoreFormula": "simWindowVolume * simCpc / simKd",
  "scoreField": "score",
  "scoreColumnHeader": "score(simWindowVolume*cpc/kd)",
  "sourcePresenceEnum": {
    "both": "关键词同时来自 SIM 与 SEM",
    "sim_only": "关键词仅来自 SIM",
    "sem_only": "关键词仅来自 SEM"
  },
  "compatibility": {
    "guarantee": "v1 当前严格兼容仓库内 word-from-root 与 word-monitor-sub-domain 的标准词表 Excel 表头",
    "headerOrderLocked": true,
    "breakingChangePolicy": "列名或顺序变更必须升级版本（如 v2）"
  },
  "excelColumns": [
    {
      "header": "keyword",
      "field": "keyword",
      "type": "string",
      "nullable": false,
      "width_profile": {
        "min": 30,
        "max": 90
      }
    },
    {
      "header": "对应域名",
      "field": "correspondingDomain",
      "type": "string",
      "nullable": true,
      "width_profile": {
        "min": 28,
        "max": 64
      }
    },
    {
      "header": "score(simWindowVolume*cpc/kd)",
      "field": "score",
      "type": "number",
      "nullable": true,
      "transform": "sim_score",
      "number_format": "0.000000",
      "width_profile": {
        "min": 28,
        "max": 36
      }
    },
    {
      "header": "volume(sim)",
      "field": "simWindowVolume",
      "type": "number",
      "nullable": true,
      "number_format": "0",
      "width_profile": {
        "min": 14,
        "max": 20
      }
    },
    {
      "header": "kd(sim)",
      "field": "simKd",
      "type": "number",
      "nullable": true,
      "number_format": "0.00",
      "width_profile": {
        "min": 12,
        "max": 18
      }
    },
    {
      "header": "cpc(sim)",
      "field": "simCpc",
      "type": "number",
      "nullable": true,
      "number_format": "0.00",
      "width_profile": {
        "min": 12,
        "max": 18
      }
    },
    {
      "header": "volume(sem)",
      "field": "semVolume",
      "type": "number",
      "nullable": true,
      "number_format": "0",
      "width_profile": {
        "min": 14,
        "max": 20
      }
    },
    {
      "header": "kd(sem)",
      "field": "semKd",
      "type": "number",
      "nullable": true,
      "number_format": "0.00",
      "width_profile": {
        "min": 12,
        "max": 18
      }
    },
    {
      "header": "cpc(sem)",
      "field": "semCpc",
      "type": "number",
      "nullable": true,
      "number_format": "0.00",
      "width_profile": {
        "min": 12,
        "max": 18
      }
    },
    {
      "header": "gefeiKD",
      "field": "gefeiKD",
      "type": "number",
      "nullable": true,
      "number_format": "0.00",
      "width_profile": {
        "min": 12,
        "max": 18
      }
    },
    {
      "header": "group",
      "field": "group",
      "type": "string",
      "nullable": true,
      "width_profile": {
        "min": 36,
        "max": 110
      }
    },
    {
      "header": "sourcePresence(SIM/SEM)",
      "field": "sourcePresence",
      "type": "enum",
      "nullable": true,
      "transform": "source_presence_label",
      "width_profile": {
        "fixed": 24
      }
    }
  ]
}
